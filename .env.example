# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://naman:ncbh1234@localhost:5433/syncepass
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.key 2048
JWT_PRIVATE_KEY_PATH=./keys/private.key
JWT_PUBLIC_KEY_PATH=./keys/public.key
JWT_ACCESS_EXPIRY=900          # 15 minutes in seconds
JWT_REFRESH_EXPIRY=604800      # 7 days in seconds

# ── Security ──────────────────────────────────────────────────────────────────
REPLAY_WINDOW_SECONDS=300      # 5 minute nonce dedup window
RATE_LIMIT_OPS_PER_SECOND=100
RATE_LIMIT_OPS_PER_MINUTE=1000

# ── CRDT / Snapshot ───────────────────────────────────────────────────────────
SNAPSHOT_OPS_THRESHOLD=500     # Take snapshot every N ops
SNAPSHOT_INTERVAL_MS=600000    # Or every 10 minutes
DOCUMENT_CACHE_TTL_MS=600000   # Evict idle documents after 10 minutes
DOCUMENT_CACHE_MAX_SIZE=200    # Max documents in memory cache

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL_MS=30000
WS_HEARTBEAT_TIMEOUT_MS=10000
WS_MAX_PAYLOAD_BYTES=131072    # 128 KB max message size
WS_SEND_QUEUE_MAX=500          # Max queued messages before slow-consumer disconnect

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                 # trace|debug|info|warn|error|fatal
